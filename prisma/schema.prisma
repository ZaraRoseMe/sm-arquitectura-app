// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINADOR
  COLABORADOR
  REPORTES
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  PAUSADO
  TERMINADO
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  name          String
  email         String?   @unique
  password      String
  role          Role      @default(COLABORADOR)
  avatar        String?
  color         String    @default("#6366F1")
  lastSeen      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasks              Task[]
  notifications      Notification[]
  pauseLogs          PauseLog[]
  timeEntries        TimeEntry[]
  workPlans          WorkPlan[]
  sentMessages       Message[]       @relation("SentMessages")
  receivedMessages   Message[]       @relation("ReceivedMessages")
  ledTeam            Team?           @relation("TeamCoordinator")
  teamMemberships    TeamMember[]
  groupMessagesSent  GroupMessage[]

  @@map("users")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  color       String    @default("#3B82F6")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parentId    String?
  parent      Project?  @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Project[] @relation("ProjectHierarchy")

  teamId      String?
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  tasks       Task[]

  @@map("projects")
}

model Task {
  id          String     @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      TaskStatus @default(PENDIENTE)
  progress    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id])

  pauseLogs     PauseLog[]
  notifications Notification[]
  timeEntries   TimeEntry[]
  workPlans     WorkPlan[]

  @@map("tasks")
}

model TimeEntry {
  id        String   @id @default(cuid())
  date      DateTime
  hours     Int      @default(0)
  minutes   Int      @default(0)
  note      String?
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

model WorkPlan {
  id        String   @id @default(cuid())
  date      DateTime
  hours     Int      @default(0)
  minutes   Int      @default(0)
  note      String?
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdBy String

  @@map("work_plans")
}

model PauseLog {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  pausedAt    DateTime  @default(now())
  resumedAt   DateTime?
  reason      String?

  @@map("pause_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Message {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

model Team {
  id            String   @id @default(cuid())
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  coordinatorId String   @unique
  coordinator   User     @relation("TeamCoordinator", fields: [coordinatorId], references: [id])
  members       TeamMember[]
  projects      Project[]
  groupMessages GroupMessage[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([teamId, userId])
  @@map("team_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("group_messages")
}
